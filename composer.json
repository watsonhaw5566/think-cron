{
  "name": "watsonhaw/think-cron",
  "description": "think cron task extend for thinkphp8",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "yunwuxin",
      "email": "448901948@qq.com"
    },
    {
      "name": "watsonhaw",
      "email": "348748267@qq.com"
    }
  ],
  "require": {
    "symfony/process": "^7.0",
    "nesbot/carbon": "^3.0",
    "dragonmantank/cron-expression": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "yunwuxin\\cron\\": "src/cron"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "yunwuxin\\cron\\tests\\": "tests"
    }
  },
  "extra": {
    "think": {
      "config": {
        "cron": "src/config.php"
      },
      "services": [
        "yunwuxin\\cron\\Service"
      ]
    }
  },
  "require-dev": {
    "topthink/framework": "^8.0",
    "topthink/think-swoole": "^4.0",
    "phpunit/phpunit": "^10.0",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^2.0"
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan --no-progress --memory-limit=1G"
  },
  "config": {
    "preferred-install": "dist",
    "platform-check": false,
    "sort-packages": true,
    "platform": {
      "ext-swoole": "4.6.0"
    }
  }
}